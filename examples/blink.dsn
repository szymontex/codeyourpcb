(pcb "blink"
  (parser
    (string_quote ")
    (space_in_quoted_tokens on)
    (host_cad "CodeYourPCB")
    (host_version "0.1.0")
  )
  (resolution mil 10)
  (unit mil)
  (structure
    (boundary
      (rect pcb 0 0 1968.5039 1181.1024)
    )
    (layer F.Cu
      (type signal)
    )
    (layer B.Cu
      (type signal)
    )
    (rule
      (width 8)
      (clearance 6)
    )
  )
  (placement
    (component "0805"
      (place "LED1" 984.2520 590.5512 front 0.0)
    )
    (component "0402"
      (place "R1" 590.5512 590.5512 front 0.0)
    )
  )
  (library
    (image "0805"
      (pin rect_39_57 "1" -37.4016 0.0000)
      (pin rect_39_57 "2" 37.4016 0.0000)
    )
    (image "0402"
      (pin rect_23_19 "1" -19.6850 0.0000)
      (pin rect_23_19 "2" 19.6850 0.0000)
    )
    (padstack rect_39_57
      (shape (rect F.Cu -19.6850 -28.5433 19.6850 28.5433))
      (attach off)
    )
    (padstack rect_23_19
      (shape (rect F.Cu -11.8110 -9.8425 11.8110 9.8425))
      (attach off)
    )
  )
  (network
    (net "VCC"
      (pins R1-1)
    )
    (net "LED_ANODE"
      (pins LED1-A R1-2)
    )
    (net "GND"
      (pins LED1-K)
    )
    (class default
 "VCC" "LED_ANODE" "GND"
      (rule
        (width 8)
        (clearance 6)
      )
    )
  )
  (wiring
  )
)
