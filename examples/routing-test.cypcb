// Routing test with numeric pin names
version 1
   
board routing_test {
    size 40mm x 25mm
    layers 2
}

component R1 resistor "0402" {
    value "10k"
    at 10mm, 12mm
}
   
component R2 resistor "0402" {
    value "10k"
    at 25mm, 12mm
}

component C1 capacitor "0402" {
    value "100nF"
    at 17mm, 8mm
}

net VCC {
    R1.1
    C1.1
}

net GND {
    R1.2
    R2.1
    C1.2
}

net SIGNAL {
    R2.2
}
