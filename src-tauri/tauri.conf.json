{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeYourPCB",
  "version": "0.1.0",
  "identifier": "com.codeyourpcb.app",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../viewer"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../viewer"
    },
    "devUrl": "http://localhost:4321",
    "frontendDist": "../viewer/dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeYourPCB",
        "maximized": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "fileAssociations": [
      {
        "ext": ["cypcb"],
        "mimeType": "application/x-codeyourpcb",
        "description": "CodeYourPCB Design File"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://releases.codeyourpcb.com/{{target}}/{{arch}}/{{current_version}}"],
      "pubkey": ""
    }
  }
}
